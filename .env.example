# Personal access token (read:user). Used locally by scripts/generate-github-stats.ts.
GITHUB_TOKEN=

# In GitHub Actions, add the same token as repository secret GH_STATS_TOKEN
# (Settings → Secrets and variables → Actions).

# OpenPanel (browser SDK — PUBLIC_ vars are embedded at build time).
PUBLIC_OPENPANEL_CLIENT_ID=
PUBLIC_OPENPANEL_API_URL=https://open-panel.vps02.yob-yob.com/api

# In GitHub Actions, add the same PUBLIC_* values as repository variables
# (Settings → Secrets and variables → Actions → Variables).

# Server-side only — never expose in client code.
OPENPANEL_CLIENT_SECRET=
