# Personal access token (read:user). Used locally by scripts/generate-github-stats.ts.
GITHUB_TOKEN=

# In GitHub Actions, add the same token as repository secret GH_STATS_TOKEN
# (Settings → Secrets and variables → Actions).

# PostHog analytics (public — safe to commit)
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://s.yob-yob.com
